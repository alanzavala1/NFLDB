              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Headshot Url"
          }
        },
        "type": "object",
        "required": [
          "player_id",
          "player_name"
        ],
        "title": "RosterPlayer"
      },
