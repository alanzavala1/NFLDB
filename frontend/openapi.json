        "properties": {
          "status": {
            "type": "string",
            "const": "ok",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "LoadSeasonResponse": {
        "properties": {
          "season": {
            "type": "integer",
            "title": "Season"
          },
          "status": {
            "type": "string",
            "enum": [
              "loaded",
              "queued",
              "loading",
              "error",
              "available"
            ],
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "season",
          "status"
        ],
        "title": "LoadSeasonResponse"
      },
