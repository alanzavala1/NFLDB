        "properties": {
          "season": {
            "type": "integer",
            "title": "Season"
          },
          "status": {
            "type": "string",
            "enum": [
              "loaded",
              "queued",
              "loading",
              "error",
              "available"
            ],
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "season",
          "status"
        ],
        "title": "SeasonStatus"
      },
      "StandingsRow": {
        "properties": {
          "team": {
            "type": "string",
            "title": "Team"
          },
          "w": {
            "type": "integer",
            "title": "W"
          },
          "l": {
            "type": "integer",
            "title": "L"
          },
          "t": {
            "type": "integer",
            "title": "T"
          },
          "pct": {
            "type": "number",
            "title": "Pct"
          },
          "pf": {
            "type": "integer",
            "title": "Pf"
          },
          "pa": {
            "type": "integer",
            "title": "Pa"
          },
          "home": {
            "type": "string",
            "title": "Home"
          },
          "away": {
            "type": "string",
            "title": "Away"
          },
          "div": {
            "type": "string",
            "title": "Div"
          },
          "strk": {
            "type": "string",
            "title": "Strk"
          },
          "gb": {
            "type": "string",
            "title": "Gb",
            "default": "\u2014"
